/*
  Content-Type / caching / security headers for Cloudflare Workers Static Assets
  Docs: https://developers.cloudflare.com/workers/static-assets/
  格式与 Cloudflare Pages 完全兼容，由 Workers Static Assets 原生解析。
*/

# ---- Long-cache static assets (1 year, immutable) ----
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ---- HTML: always revalidate ----
/
  Content-Type: text/html; charset=utf-8
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Content-Type: text/html; charset=utf-8
  Cache-Control: public, max-age=0, must-revalidate

# ---- Explicit MIME types ----
/*.css
  Content-Type: text/css; charset=utf-8

/*.js
  Content-Type: text/javascript; charset=utf-8

/*.svg
  Content-Type: image/svg+xml

# ---- Security headers (applied to everything) ----
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
